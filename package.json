{
  "name": "@void-rikk/leaf",
  "version": "1.0.2",
  "description": "Lightweight fetch wrapper with cache, retry and deduplication",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "license": "MIT",
  "keywords": [
    "fetch",
    "http",
    "api",
    "client",
    "cache",
    "retry",
    "deduplication"
  ],
  "scripts": {
    "build": "tsup",
    "test-server": "nodemon tests/test-server/test-server.ts",
    "test": "vitest"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.2",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.5.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "private": false
}
